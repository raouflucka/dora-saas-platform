# ============================================================
# DORA SaaS — Backend Environment (example)
# Copy this file to .env and fill in your values
# ============================================================

# --- Database (PostgreSQL) ---
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=DORA_DB
DB_HOST=localhost
DB_PORT=5432

# Prisma standard connection URL
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/DORA_DB?schema=public

# --- Application ---
PORT=3000
NODE_ENV=development

# --- JWT ---
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Mail (use Ethereal for dev: https://ethereal.email) ---
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_ethereal_user@ethereal.email
SMTP_PASS=your_ethereal_password
SMTP_FROM="DORA SaaS <noreply@dorasaas.local>"

# --- Frontend ---
FRONTEND_URL=http://localhost:5173
